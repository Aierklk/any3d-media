# OpenAI-compatible endpoint for visual QA (glm-5v-turbo)
QA_VISION_BASE_URL=https://open.bigmodel.cn/api/paas/v4
QA_VISION_API_KEY=your_key_here
QA_VISION_MODEL=glm-5v-turbo

# Optional: text model for narration polish (kimi-k2.6)
TEXT_MODEL_BASE_URL=https://api.moonshot.cn/v1
TEXT_MODEL_API_KEY=your_key_here
TEXT_MODEL_MODEL=moonshotai/kimi-k2.6

# Any3D local dev server (the app being recorded)
TARGET_BASE_URL=http://localhost:3000
